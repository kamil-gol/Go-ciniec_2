# ========================================
# Development Environment Configuration
# ========================================
# Runs alongside production on different ports:
#   PostgreSQL: 5434  (prod: 5432, test: 5433)
#   Backend:    4001  (prod: 3001)
#   Frontend:   4000  (prod: 3000)
#   Redis:      6380  (prod: 6379)
# ========================================

NODE_ENV=development

# Database (dev container on port 5434)
DATABASE_URL=postgresql://rezerwacje_dev:rezerwacje_dev_2026@localhost:5434/rezerwacje_dev
DB_USER=rezerwacje_dev
DB_PASSWORD=rezerwacje_dev_2026
DB_NAME=rezerwacje_dev
DB_PORT=5434

# Backend API
PORT=4001
API_PORT=4001

# JWT
JWT_SECRET=dev-secret-key-do-not-use-in-production-2026
JWT_EXPIRES_IN=7d

# CORS — allow dev frontend
CORS_ORIGIN=http://localhost:4000,http://127.0.0.1:4000

# Frontend
WEB_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4001/api
NEXT_PUBLIC_APP_NAME=System Rezerwacji - DEV

# Redis (dev on 6380)
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380

# Email (disabled in dev — uses ethereal/mailtrap or disabled)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=dev@ethereal.email
SMTP_PASS=dev-password
SMTP_FROM=dev@gosciniecrodzinny.pl

# Logging
LOG_LEVEL=debug

# File Uploads
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads-dev

# Restaurant branding
RESTAURANT_NAME=Gosciniec Rodzinny (DEV)
RESTAURANT_ADDRESS=ul. Przykladowa 123, 00-000 Miasto
RESTAURANT_PHONE=+48 123 456 789
RESTAURANT_EMAIL=kontakt@gosciniecrodzinny.pl
RESTAURANT_WEBSITE=www.gosciniecrodzinny.pl
RESTAURANT_NIP=123-456-78-90
