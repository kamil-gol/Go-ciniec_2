# ========================================
# Test Environment Configuration
# ========================================
# Used by: jest (backend), vitest (frontend), playwright (e2e)
# DB runs on port 5433 to avoid conflict with dev DB (5432)
# ========================================

NODE_ENV=test

# Database (test container on port 5433)
DATABASE_URL=postgresql://test:test@localhost:5433/rezerwacje_test
DB_USER=test
DB_PASSWORD=test
DB_NAME=rezerwacje_test
DB_PORT=5433

# Auth
JWT_SECRET=test-secret-key-do-not-use-in-production
JWT_REFRESH_SECRET=test-refresh-secret-key

# Server
PORT=3001
API_PORT=3001
LOG_LEVEL=silent

# SMTP (disabled in tests)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=test
SMTP_PASS=test
SMTP_FROM=test@test.pl

# Restaurant branding (for PDF tests)
RESTAURANT_NAME=Test Restaurant
RESTAURANT_ADDRESS=ul. Testowa 1, 00-000 Test
RESTAURANT_PHONE=+48 000 000 000
RESTAURANT_EMAIL=test@test.pl
RESTAURANT_WEBSITE=www.test.pl
RESTAURANT_NIP=000-000-00-00

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_NAME=Rezerwacje Test
