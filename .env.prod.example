# ============================================
# Production Environment — .env.prod
# ============================================
# Copy to .env.prod and fill in all values.
# NEVER commit .env.prod to git!
# ============================================

# --- Database ---
DB_USER=rezerwacje
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=rezerwacje
DB_PORT=5432

# --- Backend ---
API_PORT=3001
JWT_SECRET=CHANGE_ME_USE_openssl_rand_base64_64
JWT_REFRESH_SECRET=CHANGE_ME_USE_openssl_rand_base64_64

# --- Frontend ---
WEB_PORT=3000
NEXT_PUBLIC_API_URL=https://yourdomain.pl/api
NEXT_PUBLIC_APP_NAME=Rezerwacje Gosciniec Rodzinny

# --- SMTP ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.pl
SMTP_PASS=CHANGE_ME
SMTP_FROM=noreply@yourdomain.pl

# --- Restaurant ---
RESTAURANT_NAME=Gosciniec Rodzinny
RESTAURANT_ADDRESS=
RESTAURANT_PHONE=
RESTAURANT_EMAIL=
RESTAURANT_WEBSITE=
RESTAURANT_NIP=

# --- MinIO / Object Storage ---
STORAGE_DRIVER=minio

# Root credentials (admin only — used by MinIO server)
# Generate: openssl rand -base64 32
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_USE_openssl_rand_base64_32

# Service account credentials (used by backend)
# Generate via: ./scripts/setup-minio-prod.sh
# Or manually: openssl rand -hex 8 (access key), openssl rand -base64 32 (secret key)
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME

# Bucket names (defaults are fine)
MINIO_BUCKET_ATTACHMENTS=attachments
MINIO_BUCKET_PDFS=pdfs
MINIO_BUCKET_EXPORTS=exports

# --- Logging ---
LOG_LEVEL=warn
