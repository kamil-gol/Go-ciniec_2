# ==============================================
# Konfiguracja Systemów Backupów
# Gościniec_2 - System Rezerwacji
# ==============================================

# KATALOGI
# ---------
# Katalog gdzie będą przechowywane backupy
BACKUP_DIR=/home/kamil/backups/gosciniec

# Katalog projektu (gdzie znajduje się aplikacja)
PROJECT_DIR=/home/kamil/rezerwacje

# DOCKER
# ------
# Nazwa kontenera bazy danych
DB_CONTAINER=postgres

# BAZA DANYCH
# -----------
# Nazwa bazy danych do backupu
POSTGRES_DB=rezerwacje

# Użytkownik bazy danych
POSTGRES_USER=postgres

# Hasło do bazy danych
POSTGRES_PASSWORD=postgres

# RETENCJA
# --------
# Liczba dni przechowywania backupów (starsze zostaną usunięte)
# Przykłady:
#   RETENTION_DAYS=7   - 1 tydzień
#   RETENTION_DAYS=14  - 2 tygodnie
#   RETENTION_DAYS=30  - 1 miesiąc
RETENTION_DAYS=7

# ==============================================
# JAK UŻYĆ?
# ==============================================
# 1. Skopiuj ten plik jako .env.backup:
#    cp .env.backup.example .env.backup
#
# 2. Edytuj wartości (szczególnie hasło!):
#    nano .env.backup
#
# 3. Załaduj przed uruchomieniem skryptu:
#    source .env.backup
#    ./scripts/backup.sh
#
# 4. Lub dodaj do crona:
#    0 2 * * * cd /home/kamil/rezerwacje && source .env.backup && ./scripts/backup.sh
# ==============================================

# UWAGA BEZPIECZEŃSTWA!
# ----------------------
# - NIE commituj pliku .env.backup do Git!
# - Ten plik zawiera hasła!
# - Ustaw uprawnienia: chmod 600 .env.backup
# - Dodaj .env.backup do .gitignore
