# ==================================
# Konfiguracja Skryptu Backup
# ==================================
# Skopiuj ten plik do .env.backup i dostosuj wartości

# Katalogi
BACKUP_DIR=/home/kamil/backups/gosciniec
PROJECT_DIR=/home/kamil/rezerwacje

# Docker - UWAGA: Użyj prawdziwej nazwy kontenera!
DB_CONTAINER=rezerwacje-db  # ✅ Nazwa kontenera z docker-compose.yml

# Baza danych - dopasuj do .env głównego
POSTGRES_DB=rezerwacje
POSTGRES_USER=rezerwacje
POSTGRES_PASSWORD=your_secure_password_here

# Retencja backupów (dni)
RETENTION_DAYS=7

# ==================================
# Jak używać:
# ==================================
# 1. Skopiuj plik:
#    cp .env.backup.example .env.backup
#
# 2. Edytuj wartości:
#    nano .env.backup
#
# 3. Ustaw hasło bazy (to samo co w .env):
#    POSTGRES_PASSWORD=twoje_hasło
#
# 4. Uruchom backup:
#    cd /home/kamil/rezerwacje
#    source .env.backup
#    ./scripts/backup.sh
#
# 5. Ustaw cron (automatyczny backup):
#    crontab -e
#    # Dodaj linię:
#    0 2 * * * cd /home/kamil/rezerwacje && source .env.backup && ./scripts/backup.sh
#    # (backup codziennie o 2:00)

# ==================================
# Weryfikacja nazwy kontenera:
# ==================================
# Sprawdź jak nazywa się kontener bazy:
#   docker ps --format '{{.Names}}' | grep db
#
# Powinien pokazać: rezerwacje-db
#
# Jeśli nazwa jest inna, zaktualizuj DB_CONTAINER powyżej
