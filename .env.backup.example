# ===========================================
# Konfiguracja Backup - Gościniec Rodzinny
# ===========================================
# 
# Ten plik jest PRZYKŁADEM konfiguracji backupu.
# Skopiuj go do .env.backup i wypełnij właściwymi danymi:
#
# cp .env.backup.example .env.backup
# nano .env.backup
# chmod 600 .env.backup
#

# Katalog gdzie będą przechowywane backupy
BACKUP_DIR=/home/kamil/backups/gosciniec

# Katalog projektu
PROJECT_DIR=/home/kamil/rezerwacje

# Nazwa kontenera Docker z bazą danych
# Sprawdź: docker ps --format '{{.Names}}' | grep db
DB_CONTAINER=rezerwacje-db

# Credentials do PostgreSQL
# WAŻNE: Użyj tych samych wartości co w docker-compose.yml!
POSTGRES_DB=rezerwacje
POSTGRES_USER=rezerwacje
POSTGRES_PASSWORD=your_secure_password_here

# Retencja backupów (ile dni przechowywać)
# 30 dni = ~1 miesiąc historii backupów
RETENTION_DAYS=30

# ===========================================
# UWAGA BEZPIECZEŃSTWA:
# ===========================================
# Po utworzeniu .env.backup z właściwymi danymi:
# 1. chmod 600 .env.backup  (tylko root może czytać)
# 2. Nigdy nie commituj .env.backup do repo!
# 3. Plik .env.backup jest w .gitignore
