# ============================================
# Environment Variables Template
# ============================================
# Copy this file to create environment-specific configs:
#   cp .env.example .env.dev    (for development)
#   cp .env.example .env.prod   (for production)
#
# NEVER commit .env.dev or .env.prod to git!
# ============================================

# Application
NODE_ENV=development

# Database
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=5432

# Backend API
API_PORT=3001

# JWT (generate with: openssl rand -hex 32)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Frontend
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_NAME=System Rezerwacji - Gosciniec Rodzinny

# Redis
REDIS_PORT=6379

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@gosciniecrodzinny.pl

# Logging
LOG_LEVEL=info

# Restaurant Branding
RESTAURANT_NAME=Gosciniec Rodzinny
RESTAURANT_ADDRESS=
RESTAURANT_PHONE=
RESTAURANT_EMAIL=
RESTAURANT_WEBSITE=
RESTAURANT_NIP=

# File Uploads
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Backup
BACKUP_PATH=./backups
