# ==========================================
# Environment Variables
# ==========================================

# Node Environment
NODE_ENV=development

# ==========================================
# DATABASE
# ==========================================
DB_USER=rezerwacje
DB_PASSWORD=rezerwacje_secure_pass_2026
DB_NAME=rezerwacje
DB_PORT=5432
DATABASE_URL=postgresql://rezerwacje:rezerwacje_secure_pass_2026@postgres:5432/rezerwacje

# ==========================================
# API / BACKEND
# ==========================================
API_PORT=3001
API_HOST=0.0.0.0
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRATION=7d
LOG_LEVEL=info

# ==========================================
# FRONTEND
# ==========================================
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_NAME=Rezerwacje Gościniec Rodzinny

# ==========================================
# REDIS (Caching & Sessions)
# ==========================================
REDIS_URL=redis://redis:6379
REDIS_PORT=6379
SESSION_SECRET=your-session-secret-min-32-chars

# ==========================================
# EMAIL (SMTP)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@gosciniecrodzinny.pl
SMTP_FROM_NAME=Gościniec Rodzinny

# ==========================================
# FILE UPLOADS
# ==========================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,application/pdf

# ==========================================
# BACKUPS
# ==========================================
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * * # 2 AM daily

# ==========================================
# RESTAURANT INFO
# ==========================================
RESTAURANT_NAME=Gościniec Rodzinny
RESTAURANT_ADDRESS=ul. Bukowa 155, 41-600 Świętochłowice
RESTAURANT_PHONE=+48 32 XXX XXXX
RESTAURANT_EMAIL=kontakt@gosciniecrodzinny.pl
RESTAURANT_WEBSITE=https://gosciniecrodzinny.pl

# ==========================================
# PASSWORD REQUIREMENTS
# ==========================================
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true

# ==========================================
# DEFAULTS
# ==========================================
DEFAULT_RESERVATION_HOURS=6
DEFAULT_CURRENCY=PLN
DEFAULT_TIMEZONE=Europe/Warsaw
DEFAULT_DATE_FORMAT=dd.mm.yyyy
DEFAULT_TIME_FORMAT=HH:mm

# ==========================================
# PAGINATION
# ==========================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ==========================================
# FEATURES
# ==========================================
FEATURE_REMINDER_EMAILS=true
FEATURE_SMS_NOTIFICATIONS=false
FEATURE_DEPOSIT_SYSTEM=true
FEATURE_AUTO_BACKUP=true
FEATURE_ANALYTICS=true