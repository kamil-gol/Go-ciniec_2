# E2E Test Environment Variables

# Base URLs
E2E_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Test Users
E2E_ADMIN_EMAIL=admin@test.com
E2E_ADMIN_PASSWORD=TestAdmin123!

E2E_EMPLOYEE_EMAIL=employee@test.com
E2E_EMPLOYEE_PASSWORD=TestEmployee123!

E2E_CLIENT_EMAIL=client@test.com
E2E_CLIENT_PASSWORD=TestClient123!

# Test Database
E2E_DATABASE_URL=postgresql://rezerwacje:rezerwacje@localhost:5432/rezerwacje_test

# Test Configuration
E2E_HEADLESS=true
E2E_SLOWMO=0
E2E_TIMEOUT=60000
E2E_RETRIES=2

# Screenshots & Videos
E2E_SCREENSHOT_ON_FAILURE=true
E2E_VIDEO_ON_FAILURE=true
E2E_TRACE_ON_RETRY=true
