{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend for Rezerwacje system",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "lint": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "jest --config jest.config.cjs --selectProjects unit --passWithNoTests && jest --config jest.config.cjs --selectProjects integration --runInBand --passWithNoTests",
    "test:unit": "jest --config jest.config.cjs --selectProjects unit --passWithNoTests",
    "test:integration": "jest --config jest.config.cjs --selectProjects integration --runInBand --passWithNoTests",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage --passWithNoTests",
    "test:ci": "jest --config jest.config.cjs --selectProjects unit --coverage --ci --forceExit --detectOpenHandles --passWithNoTests && jest --config jest.config.cjs --selectProjects integration --runInBand --ci --forceExit --detectOpenHandles --passWithNoTests",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:test": "dotenv -e ../../.env.test -- prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && tsx prisma/seed.ts",
    "db:test:setup": "docker compose -f ../../docker-compose.test.yml up -d postgres-test && sleep 2 && npm run prisma:migrate:test",
    "db:test:teardown": "docker compose -f ../../docker-compose.test.yml down -v"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "dotenv-cli": "^7.4.2",
    "exceljs": "^4.5.0",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "marked": "^15.0.0",
    "minio": "^8.0.5",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.3",
    "pdfkit": "^0.16.0",
    "pg": "^8.13.0",
    "sharp": "^0.33.2",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "overrides": {
    "glob": "^10.4.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/pdfkit": "^0.13.4",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.7",
    "jest": "^30.0.0",
    "prisma": "^7.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
