generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email               String               @unique @db.VarChar(255)
  password            String               @db.VarChar(255)
  firstName           String               @db.VarChar(100)
  lastName            String               @db.VarChar(100)
  role                String               @default("EMPLOYEE") @db.VarChar(20)
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  activityLogs        ActivityLog[]
  createdReservations Reservation[]        @relation("CreatedBy")
  createdHistories    ReservationHistory[] @relation("ChangedBy")

  @@index([email])
  @@index([role])
}

model Hall {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String        @unique @db.VarChar(255)
  capacity        Int           @db.SmallInt
  pricePerPerson  Decimal       @db.Decimal(10, 2)
  description     String?
  amenities       String[]
  images          String[]
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  pricePerChild   Decimal?      @db.Decimal(10, 2)
  pricePerToddler Decimal?      @db.Decimal(10, 2)
  reservations    Reservation[]

  @@index([name])
  @@index([isActive])
}

model EventType {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String         @unique @db.VarChar(100)
  description   String?
  color         String?        @db.VarChar(20)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  menuTemplates MenuTemplate[]
  reservations  Reservation[]

  @@index([name])
  @@index([isActive])
}

model Client {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName    String        @db.VarChar(100)
  lastName     String        @db.VarChar(100)
  email        String?       @db.VarChar(255)
  phone        String        @db.VarChar(20)
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  reservations Reservation[]

  @@index([email])
  @@index([phone])
  @@index([firstName, lastName])
}

model Reservation {
  id                       String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hallId                   String?                  @db.Uuid
  clientId                 String                   @db.Uuid
  eventTypeId              String?                  @db.Uuid
  createdById              String                   @db.Uuid
  date                     String?                  @db.VarChar(10)
  startTime                String?                  @db.VarChar(5)
  endTime                  String?                  @db.VarChar(5)
  guests                   Int                      @db.SmallInt
  totalPrice               Decimal                  @db.Decimal(10, 2)
  notes                    String?
  attachments              String[]
  archivedAt               DateTime?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  adults                   Int                      @default(0) @db.SmallInt
  children                 Int                      @default(0) @db.SmallInt
  pricePerAdult            Decimal                  @default(0) @db.Decimal(10, 2)
  pricePerChild            Decimal                  @default(0) @db.Decimal(10, 2)
  confirmationDeadline     DateTime?
  startDateTime            DateTime?
  endDateTime              DateTime?
  customEventType          String?                  @db.VarChar(100)
  anniversaryYear          Int?                     @db.SmallInt
  anniversaryOccasion      String?                  @db.VarChar(100)
  birthdayAge              Int?                     @db.SmallInt
  toddlers                 Int                      @default(0) @db.SmallInt
  pricePerToddler          Decimal                  @default(0) @db.Decimal(10, 2)
  reservationQueuePosition Int?                     @db.SmallInt
  reservationQueueDate     DateTime?
  queueOrderManual         Boolean                  @default(false)
  status                   ReservationStatus        @default(RESERVED)
  deposits                 Deposit[]
  client                   Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy                User                     @relation("CreatedBy", fields: [createdById], references: [id])
  eventType                EventType?               @relation(fields: [eventTypeId], references: [id])
  hall                     Hall?                    @relation(fields: [hallId], references: [id], onDelete: Restrict)
  history                  ReservationHistory[]
  menuSnapshot             ReservationMenuSnapshot?

  @@index([date])
  @@index([startDateTime])
  @@index([reservationQueueDate])
  @@index([reservationQueuePosition])
  @@index([hallId])
  @@index([clientId])
  @@index([status])
  @@index([createdById])
  @@index([confirmationDeadline])
  @@index([queueOrderManual])
}

model ReservationHistory {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservationId   String      @db.Uuid
  changedByUserId String      @db.Uuid
  changeType      String      @db.VarChar(20)
  fieldName       String?     @db.VarChar(100)
  oldValue        String?
  newValue        String?
  reason          String?
  createdAt       DateTime    @default(now())
  changedByUser   User        @relation("ChangedBy", fields: [changedByUserId], references: [id])
  reservation     Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@index([changedByUserId])
  @@index([createdAt])
}

model Deposit {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservationId String      @db.Uuid
  amount        Decimal     @db.Decimal(10, 2)
  dueDate       String      @db.VarChar(10)
  paid          Boolean     @default(false)
  paidAt        DateTime?
  paymentMethod String?     @db.VarChar(50)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  status        String      @default("PENDING") @db.VarChar(20)
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@index([dueDate])
  @@index([status])
  @@index([paid])
}

model ActivityLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String?  @db.Uuid
  action     String   @db.VarChar(100)
  entityType String?  @db.VarChar(50)
  entityId   String?  @db.VarChar(100)
  details    Json?
  ipAddress  String?  @db.Inet
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

model MenuTemplate {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventTypeId  String             @db.Uuid
  name         String             @db.VarChar(255)
  description  String?
  variant      String?            @db.VarChar(100)
  validFrom    DateTime
  validTo      DateTime?
  isActive     Boolean            @default(true)
  displayOrder Int                @default(0) @db.SmallInt
  imageUrl     String?
  thumbnailUrl String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  packages     MenuPackage[]
  priceHistory MenuPriceHistory[]
  eventType    EventType          @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)

  @@index([eventTypeId])
  @@index([isActive])
  @@index([validFrom, validTo])
  @@index([variant])
}

model MenuPackage {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  menuTemplateId   String              @db.Uuid
  name             String              @db.VarChar(255)
  description      String?
  shortDescription String?             @db.VarChar(500)
  pricePerAdult    Decimal             @db.Decimal(10, 2)
  pricePerChild    Decimal             @default(0) @db.Decimal(10, 2)
  pricePerToddler  Decimal             @default(0) @db.Decimal(10, 2)
  color            String?             @db.VarChar(20)
  icon             String?             @db.VarChar(50)
  badgeText        String?             @db.VarChar(50)
  displayOrder     Int                 @default(0) @db.SmallInt
  isPopular        Boolean             @default(false)
  isRecommended    Boolean             @default(false)
  includedItems    String[]
  minGuests        Int?                @db.SmallInt
  maxGuests        Int?                @db.SmallInt
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  courses          MenuCourse[]
  menuTemplate     MenuTemplate        @relation(fields: [menuTemplateId], references: [id], onDelete: Cascade)
  packageOptions   MenuPackageOption[]
  priceHistory     MenuPriceHistory[]

  @@index([menuTemplateId])
  @@index([displayOrder])
  @@index([isPopular])
}

model MenuOption {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String              @db.VarChar(255)
  description      String?
  shortDescription String?             @db.VarChar(500)
  category         String              @db.VarChar(100)
  priceType        String              @db.VarChar(20)
  priceAmount      Decimal             @default(0) @db.Decimal(10, 2)
  allowMultiple    Boolean             @default(false)
  maxQuantity      Int                 @default(1) @db.SmallInt
  icon             String?             @db.VarChar(50)
  imageUrl         String?
  thumbnailUrl     String?
  isActive         Boolean             @default(true)
  displayOrder     Int                 @default(0) @db.SmallInt
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  packageOptions   MenuPackageOption[]
  priceHistory     MenuPriceHistory[]

  @@index([category])
  @@index([isActive])
  @@index([priceType])
}

model MenuPackageOption {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  packageId    String      @db.Uuid
  optionId     String      @db.Uuid
  customPrice  Decimal?    @db.Decimal(10, 2)
  isRequired   Boolean     @default(false)
  isDefault    Boolean     @default(false)
  isExclusive  Boolean     @default(false)
  displayOrder Int         @default(0) @db.SmallInt
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  option       MenuOption  @relation(fields: [optionId], references: [id], onDelete: Cascade)
  package      MenuPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([packageId, optionId])
  @@index([packageId])
  @@index([optionId])
}

model Dish {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String             @db.VarChar(255)
  description   String?
  category      DishCategory
  allergens     String[]
  priceModifier Decimal            @default(0) @db.Decimal(10, 2)
  imageUrl      String?
  thumbnailUrl  String?
  isActive      Boolean            @default(true)
  displayOrder  Int                @default(0) @db.SmallInt
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  courseOptions MenuCourseOption[]

  @@index([category])
  @@index([isActive])
  @@index([name])
}

model MenuCourse {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  packageId    String             @db.Uuid
  name         String             @db.VarChar(255)
  description  String?
  minSelect    Int                @default(1) @db.SmallInt
  maxSelect    Int                @default(1) @db.SmallInt
  isRequired   Boolean            @default(true)
  displayOrder Int                @default(0) @db.SmallInt
  icon         String?            @db.VarChar(50)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  package      MenuPackage        @relation(fields: [packageId], references: [id], onDelete: Cascade)
  options      MenuCourseOption[]

  @@index([packageId])
  @@index([displayOrder])
}

model MenuCourseOption {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId      String     @db.Uuid
  dishId        String     @db.Uuid
  customPrice   Decimal?   @db.Decimal(10, 2)
  isDefault     Boolean    @default(false)
  isRecommended Boolean    @default(false)
  displayOrder  Int        @default(0) @db.SmallInt
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  course        MenuCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  dish          Dish       @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@unique([courseId, dishId])
  @@index([courseId])
  @@index([dishId])
}

model ReservationMenuSnapshot {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservationId  String      @unique @db.Uuid
  menuData       Json
  menuTemplateId String?     @db.Uuid
  packageId      String?     @db.Uuid
  packagePrice   Decimal     @db.Decimal(10, 2)
  optionsPrice   Decimal     @default(0) @db.Decimal(10, 2)
  totalMenuPrice Decimal     @db.Decimal(10, 2)
  adultsCount    Int         @db.SmallInt
  childrenCount  Int         @db.SmallInt
  toddlersCount  Int         @db.SmallInt
  selectedAt     DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  reservation    Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@index([menuTemplateId])
  @@index([packageId])
  @@index([selectedAt])
}

model MenuPriceHistory {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType     String        @db.VarChar(50)
  entityId       String        @db.Uuid
  menuTemplateId String?       @db.Uuid
  packageId      String?       @db.Uuid
  optionId       String?       @db.Uuid
  fieldName      String        @db.VarChar(50)
  oldValue       Decimal       @db.Decimal(10, 2)
  newValue       Decimal       @db.Decimal(10, 2)
  changeReason   String?
  effectiveFrom  DateTime      @default(now())
  createdAt      DateTime      @default(now())
  menuTemplate   MenuTemplate? @relation(fields: [menuTemplateId], references: [id], onDelete: Cascade)
  option         MenuOption?   @relation(fields: [optionId], references: [id], onDelete: Cascade)
  package        MenuPackage?  @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([menuTemplateId])
  @@index([packageId])
  @@index([optionId])
  @@index([effectiveFrom])
}

enum ReservationStatus {
  RESERVED
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum DishCategory {
  SOUP
  MAIN_COURSE
  MEAT
  SIDE_DISH
  SALAD
  APPETIZER
  DESSERT
  DRINK
  COLD_CUTS
  SNACK
  BREAKFAST
  OTHER
}
