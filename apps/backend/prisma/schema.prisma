// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  firstName String   @db.VarChar(100)
  lastName  String   @db.VarChar(100)
  role      String   @default("EMPLOYEE") @db.VarChar(20)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdReservations  Reservation[]          @relation("CreatedBy")
  createdHistories     ReservationHistory[]   @relation("ChangedBy")
  activityLogs         ActivityLog[]

  @@index([email])
  @@index([role])
}

model Hall {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String   @unique @db.VarChar(255)
  capacity        Int      @db.SmallInt
  pricePerPerson  Decimal  @db.Decimal(10, 2) // Price per adult
  pricePerChild   Decimal? @db.Decimal(10, 2) // Price per child (4-12 years)
  pricePerToddler Decimal? @db.Decimal(10, 2) // Price per toddler (0-3 years)
  description     String?  @db.Text
  amenities       String[] @db.Text
  images          String[] @db.Text
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reservations    Reservation[]

  @@index([name])
  @@index([isActive])
}

model EventType {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  color       String?  @db.VarChar(20)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reservations  Reservation[]
  menuTemplates MenuTemplate[]

  @@index([name])
  @@index([isActive])
}

model Client {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName String   @db.VarChar(100)
  lastName  String   @db.VarChar(100)
  email     String?  @db.VarChar(255)
  phone     String   @db.VarChar(20)
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reservations Reservation[]

  @@index([email])
  @@index([phone])
  @@index([firstName, lastName])
}

enum ReservationStatus {
  RESERVED    // Lista rezerwowa - minimalny zakres danych
  PENDING     // Oczekująca - kompletne dane, czeka na potwierdzenie
  CONFIRMED   // Potwierdzona
  COMPLETED   // Zakończona
  CANCELLED   // Anulowana
}

model Reservation {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  // CORE FIELDS - Required for all statuses
  clientId        String   @db.Uuid
  createdById     String   @db.Uuid
  
  // QUEUE SYSTEM - Only for RESERVED status
  reservationQueuePosition Int?     @db.SmallInt // Position in queue for given day (1, 2, 3...)
  reservationQueueDate     DateTime? // The day this reservation is queued for
  queueOrderManual         Boolean  @default(false) // If true, position was manually set (skip auto-recalculation)
  
  // OPTIONAL FIELDS - Required only after promotion from RESERVED
  hallId          String?  @db.Uuid
  eventTypeId     String?  @db.Uuid

  // Legacy fields (kept for backwards compatibility during transition)
  date            String?  @db.VarChar(10)
  startTime       String?  @db.VarChar(5)
  endTime         String?  @db.VarChar(5)
  
  // New DateTime fields for start and end - Optional for RESERVED
  startDateTime   DateTime?
  endDateTime     DateTime?
  
  // Guest count fields - UPDATED: Split into three age groups
  adults          Int      @default(0) @db.SmallInt // Number of adults
  children        Int      @default(0) @db.SmallInt // Number of children (4-12)
  toddlers        Int      @default(0) @db.SmallInt // NEW: Number of toddlers (0-3)
  guests          Int      @db.SmallInt // Computed: adults + children + toddlers
  
  // Pricing fields - UPDATED: Three separate prices - Optional for RESERVED
  pricePerAdult   Decimal  @default(0) @db.Decimal(10, 2) // Price per adult
  pricePerChild   Decimal  @default(0) @db.Decimal(10, 2) // Price per child (4-12)
  pricePerToddler Decimal  @default(0) @db.Decimal(10, 2) // NEW: Price per toddler (0-3)
  totalPrice      Decimal  @db.Decimal(10, 2) // Computed: (adults * pricePerAdult) + (children * pricePerChild) + (toddlers * pricePerToddler)
  
  status          ReservationStatus @default(RESERVED)
  confirmationDeadline DateTime? // New: for PENDING status, deadline to confirm (max 1 day before event)
  
  notes           String?  @db.Text

  // Custom event type (when EventType = "Inne")
  customEventType String?  @db.VarChar(100)
  
  // Birthday details (when EventType = "Urodziny")
  birthdayAge     Int?     @db.SmallInt
  
  // Anniversary details (when EventType = "Rocznica")
  anniversaryYear     Int?     @db.SmallInt
  anniversaryOccasion String?  @db.VarChar(100)

  attachments     String[] @db.Text
  archivedAt      DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  hall            Hall?     @relation(fields: [hallId], references: [id], onDelete: Restrict)
  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  eventType       EventType? @relation(fields: [eventTypeId], references: [id])
  createdBy       User      @relation("CreatedBy", fields: [createdById], references: [id])

  history         ReservationHistory[]
  deposits        Deposit[]
  menuSnapshot    ReservationMenuSnapshot?

  @@index([date])
  @@index([startDateTime])
  @@index([reservationQueueDate])
  @@index([reservationQueuePosition])
  @@index([hallId])
  @@index([clientId])
  @@index([status])
  @@index([createdById])
  @@index([confirmationDeadline])
  @@index([queueOrderManual])
}

model ReservationHistory {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservationId   String   @db.Uuid
  changedByUserId String   @db.Uuid

  changeType      String   @db.VarChar(20)
  fieldName       String?  @db.VarChar(100)
  oldValue        String?  @db.Text
  newValue        String?  @db.Text
  reason          String?  @db.Text

  createdAt       DateTime @default(now())

  reservation     Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  changedByUser   User @relation("ChangedBy", fields: [changedByUserId], references: [id])

  @@index([reservationId])
  @@index([changedByUserId])
  @@index([createdAt])
}

model Deposit {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservationId   String   @db.Uuid

  amount          Decimal  @db.Decimal(10, 2)
  dueDate         String   @db.VarChar(10)
  status          String   @default("PENDING") @db.VarChar(20) // PENDING, PAID
  paid            Boolean  @default(false)
  paidAt          DateTime?
  paymentMethod   String?  @db.VarChar(50)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reservation     Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@index([dueDate])
  @@index([status])
  @@index([paid])
}

model ActivityLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String?  @db.Uuid

  action          String   @db.VarChar(100)
  entityType      String?  @db.VarChar(50)
  entityId        String?  @db.VarChar(100)
  details         Json?

  ipAddress       String?  @db.Inet
  userAgent       String?  @db.Text

  createdAt       DateTime @default(now())

  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

// ═══════════════════════════════════════════════════════════
// 🍽️ MENU SYSTEM
// ═══════════════════════════════════════════════════════════

// Menu Template - Base template for event type (e.g., "Wedding Menu Spring 2026")
model MenuTemplate {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventTypeId   String   @db.Uuid
  
  name          String   @db.VarChar(255) // "Menu Weselne Wiosna 2026"
  description   String?  @db.Text
  variant       String?  @db.VarChar(100) // "Zimowe", "Letnie", "Świąteczne" (seasonal variants)
  
  // Active period
  validFrom     DateTime
  validTo       DateTime?
  isActive      Boolean  @default(true)
  
  // UI metadata
  displayOrder  Int      @default(0) @db.SmallInt
  imageUrl      String?  @db.Text
  thumbnailUrl  String?  @db.Text
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  eventType     EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  packages      MenuPackage[]
  priceHistory  MenuPriceHistory[]
  
  @@index([eventTypeId])
  @@index([isActive])
  @@index([validFrom, validTo])
  @@index([variant])
}

// Menu Package - Pricing tier in template (Basic, Standard, Premium)
model MenuPackage {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  menuTemplateId  String   @db.Uuid
  
  name            String   @db.VarChar(255) // "Pakiet Złoty"
  description     String?  @db.Text
  shortDescription String? @db.VarChar(500) // For card preview
  
  // Pricing per guest type
  pricePerAdult   Decimal  @db.Decimal(10, 2)
  pricePerChild   Decimal  @default(0) @db.Decimal(10, 2)
  pricePerToddler Decimal  @default(0) @db.Decimal(10, 2)
  
  // UI styling
  color           String?  @db.VarChar(20) // "#FFD700" for gradients
  icon            String?  @db.VarChar(50) // "star", "crown", "diamond"
  badgeText       String?  @db.VarChar(50) // "Najpopularniejszy", "Premium"
  displayOrder    Int      @default(0) @db.SmallInt
  isPopular       Boolean  @default(false) // Show "Popular" badge
  isRecommended   Boolean  @default(false) // Show "Recommended" badge
  
  // Included features (array of strings)
  includedItems   String[] @db.Text // ["Tort 3-piętrowy", "Kelnerzy (2 osoby)", "Obrus premium"]
  
  // Min/max guests recommendation
  minGuests       Int?     @db.SmallInt
  maxGuests       Int?     @db.SmallInt
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  menuTemplate    MenuTemplate @relation(fields: [menuTemplateId], references: [id], onDelete: Cascade)
  packageOptions  MenuPackageOption[]
  courses         MenuCourse[] // NEW: Courses in this package
  priceHistory    MenuPriceHistory[]
  
  @@index([menuTemplateId])
  @@index([displayOrder])
  @@index([isPopular])
}

// Menu Option - Additional service/item (DJ, Open Bar, Photographer)
model MenuOption {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  name          String   @db.VarChar(255) // "DJ + Nagłośnienie"
  description   String?  @db.Text
  shortDescription String? @db.VarChar(500)
  category      String   @db.VarChar(100) // "Muzyka", "Alkohol", "Dekoracje", "Foto/Video"
  
  // Pricing
  priceType     String   @db.VarChar(20) // "PER_PERSON", "FLAT", "FREE"
  priceAmount   Decimal  @default(0) @db.Decimal(10, 2)
  
  // Multiplier support (e.g., 2x DJ)
  allowMultiple Boolean  @default(false)
  maxQuantity   Int      @default(1) @db.SmallInt
  
  // UI
  icon          String?  @db.VarChar(50)
  imageUrl      String?  @db.Text
  thumbnailUrl  String?  @db.Text
  
  // Availability
  isActive      Boolean  @default(true)
  displayOrder  Int      @default(0) @db.SmallInt
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  packageOptions MenuPackageOption[]
  priceHistory   MenuPriceHistory[]
  
  @@index([category])
  @@index([isActive])
  @@index([priceType])
}

// Junction table: Package <-> Options with custom pricing
model MenuPackageOption {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  packageId     String   @db.Uuid
  optionId      String   @db.Uuid
  
  // Price override for this package (null = use option default)
  customPrice   Decimal? @db.Decimal(10, 2)
  
  // Behavior flags
  isRequired    Boolean  @default(false) // Must be selected
  isDefault     Boolean  @default(false) // Pre-selected in UI
  isExclusive   Boolean  @default(false) // Can't be selected with other options in category
  
  displayOrder  Int      @default(0) @db.SmallInt
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  package       MenuPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  option        MenuOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  
  @@unique([packageId, optionId])
  @@index([packageId])
  @@index([optionId])
}

// ═══════════════════════════════════════════════════════════
// 🍽️ DISH LIBRARY & MENU COURSES (NEW)
// ═══════════════════════════════════════════════════════════

// Dish Category Enum
enum DishCategory {
  SOUP           // Zupy
  MAIN_COURSE    // Danie główne
  MEAT           // Mięso
  SIDE_DISH      // Dodatki (ziemniaki, ryż, buraki)
  SALAD          // Sałatki
  APPETIZER      // Przystawki
  DESSERT        // Desery
  DRINK          // Napoje
  COLD_CUTS      // Zimna płyta
  SNACK          // Podwieczorek
  BREAKFAST      // Śniadanie
  OTHER          // Inne
}

// Dish - Global library of all dishes
model Dish {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  name          String        @db.VarChar(255) // "Rosoł z makaronem"
  description   String?       @db.Text
  category      DishCategory  // SOUP, MAIN_COURSE, etc.
  
  // Allergen info
  allergens     String[]      @db.Text // ["gluten", "laktoza", "orzechy"]
  
  // Price modifier (additional charge for premium dishes)
  priceModifier Decimal       @default(0) @db.Decimal(10, 2) // +5zł for premium dish
  
  // UI
  imageUrl      String?       @db.Text
  thumbnailUrl  String?       @db.Text
  
  // Availability
  isActive      Boolean       @default(true)
  displayOrder  Int           @default(0) @db.SmallInt
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  // Relations
  courseOptions MenuCourseOption[]
  
  @@index([category])
  @@index([isActive])
  @@index([name])
}

// Menu Course - A course within a package (e.g., "Soup", "Main Course", "Dessert")
model MenuCourse {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  packageId     String   @db.Uuid
  
  name          String   @db.VarChar(255) // "Zupa", "Danie główne", "Deser"
  description   String?  @db.Text // "Wybierz maksymalnie 2 zupy"
  
  // Selection limits
  minSelect     Int      @default(1) @db.SmallInt // Minimum dishes to select
  maxSelect     Int      @default(1) @db.SmallInt // Maximum dishes to select
  
  // Behavior
  isRequired    Boolean  @default(true) // Must be selected by client
  
  // UI
  displayOrder  Int      @default(0) @db.SmallInt
  icon          String?  @db.VarChar(50) // "soup", "meat", "cake"
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  package       MenuPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  options       MenuCourseOption[]
  
  @@index([packageId])
  @@index([displayOrder])
}

// Menu Course Option - Junction: Course <-> Dish (what dishes are available in this course)
model MenuCourseOption {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId      String   @db.Uuid
  dishId        String   @db.Uuid
  
  // Price override for this specific course (null = use dish default priceModifier)
  customPrice   Decimal? @db.Decimal(10, 2)
  
  // Behavior
  isDefault     Boolean  @default(false) // Pre-selected in UI
  isRecommended Boolean  @default(false) // Show "Polecane" badge
  
  displayOrder  Int      @default(0) @db.SmallInt
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  course        MenuCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  dish          Dish @relation(fields: [dishId], references: [id], onDelete: Cascade)
  
  @@unique([courseId, dishId])
  @@index([courseId])
  @@index([dishId])
}

// Reservation Menu Snapshot - Immutable copy of selected menu
model ReservationMenuSnapshot {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservationId   String   @unique @db.Uuid
  
  // Snapshot data (full JSON for history preservation)
  menuData        Json     // { template, package, options, courses, dishes, prices, etc. }
  
  // References (may be null if template/package deleted)
  menuTemplateId  String?  @db.Uuid
  packageId       String?  @db.Uuid
  
  // Calculated totals at selection time
  packagePrice    Decimal  @db.Decimal(10, 2) // Package cost (per guest × guests)
  optionsPrice    Decimal  @default(0) @db.Decimal(10, 2) // Sum of selected options
  totalMenuPrice  Decimal  @db.Decimal(10, 2) // packagePrice + optionsPrice
  
  // Guest breakdown for price calculation
  adultsCount     Int      @db.SmallInt
  childrenCount   Int      @db.SmallInt
  toddlersCount   Int      @db.SmallInt
  
  selectedAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  reservation     Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  
  @@index([reservationId])
  @@index([menuTemplateId])
  @@index([packageId])
  @@index([selectedAt])
}

// Price History - Track all price changes for auditing
model MenuPriceHistory {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  // What changed
  entityType      String   @db.VarChar(50) // "TEMPLATE", "PACKAGE", "OPTION"
  entityId        String   @db.Uuid
  
  // References (optional, one will be filled)
  menuTemplateId  String?  @db.Uuid
  packageId       String?  @db.Uuid
  optionId        String?  @db.Uuid
  
  // Price change details
  fieldName       String   @db.VarChar(50) // "pricePerAdult", "priceAmount", etc.
  oldValue        Decimal  @db.Decimal(10, 2)
  newValue        Decimal  @db.Decimal(10, 2)
  changeReason    String?  @db.Text
  
  // When effective
  effectiveFrom   DateTime @default(now())
  
  createdAt       DateTime @default(now())
  
  menuTemplate    MenuTemplate? @relation(fields: [menuTemplateId], references: [id], onDelete: Cascade)
  package         MenuPackage? @relation(fields: [packageId], references: [id], onDelete: Cascade)
  option          MenuOption? @relation(fields: [optionId], references: [id], onDelete: Cascade)
  
  @@index([entityType, entityId])
  @@index([menuTemplateId])
  @@index([packageId])
  @@index([optionId])
  @@index([effectiveFrom])
}
