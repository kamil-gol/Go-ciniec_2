// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
}

// ═════════════════════════════════════════════════════════════════
// 🔐 RBAC SYSTEM — Roles & Granular Permissions
// ═════════════════════════════════════════════════════════════════

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique @db.VarChar(50)
  slug        String   @unique @db.VarChar(50)
  description String?  @db.Text
  color       String?  @db.VarChar(20)
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  users       User[]

  @@index([slug])
  @@index([isActive])
}

model Permission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  module      String   @db.VarChar(50)
  action      String   @db.VarChar(50)
  slug        String   @unique @db.VarChar(100)
  name        String   @db.VarChar(150)
  description String?  @db.Text
  createdAt   DateTime @default(now())

  roles       RolePermission[]

  @@unique([module, action])
  @@index([module])
}

model RolePermission {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  createdAt    DateTime   @default(now())

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model CompanySettings {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyName     String   @db.VarChar(255)
  nip             String?  @db.VarChar(20)
  regon           String?  @db.VarChar(20)
  address         String?  @db.Text
  city            String?  @db.VarChar(100)
  postalCode      String?  @db.VarChar(10)
  phone           String?  @db.VarChar(20)
  email           String?  @db.VarChar(255)
  website         String?  @db.VarChar(255)
  logoUrl         String?  @db.Text
  defaultCurrency String   @default("PLN") @db.VarChar(3)
  timezone        String   @default("Europe/Warsaw") @db.VarChar(50)
  invoicePrefix   String?  @db.VarChar(20)
  receiptPrefix   String?  @db.VarChar(20)
  archiveAfterDays Int     @default(30) @db.SmallInt
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ═════════════════════════════════════════════════════════════════
// 👤 USER
// ═════════════════════════════════════════════════════════════════

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  firstName String   @db.VarChar(100)
  lastName  String   @db.VarChar(100)

  legacyRole String?  @map("role") @db.VarChar(20)

  roleId    String?  @db.Uuid
  assignedRole Role?  @relation(fields: [roleId], references: [id])

  isActive  Boolean  @default(true)
  lastLoginAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdReservations  Reservation[]          @relation("CreatedBy")
  createdHistories     ReservationHistory[]   @relation("ChangedBy")
  activityLogs         ActivityLog[]
  uploadedAttachments  Attachment[]           @relation("UploadedBy")
  passwordResetTokens  PasswordResetToken[]
  refreshTokens        RefreshToken[]
  documentTemplateChanges DocumentTemplateHistory[]
  createdCateringOrders   CateringOrder[]        @relation("CateringOrderCreatedBy")
  cateringOrderHistories  CateringOrderHistory[] @relation("CateringOrderChangedBy")
  notifications           Notification[]

  @@index([email])
  @@index([roleId])
}

// ═════════════════════════════════════════════════════════════════
// 🔑 PASSWORD RESET TOKENS
// ═════════════════════════════════════════════════════════════════

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token     String    @unique @db.VarChar(255)
  userId    String    @db.Uuid
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

// ═════════════════════════════════════════════════════════════════
// 🔄 REFRESH TOKENS (#145 — session management)
// ═════════════════════════════════════════════════════════════════

model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token     String    @unique @db.VarChar(255)
  userId    String    @db.Uuid
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model Hall {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String   @unique @db.VarChar(255)
  capacity              Int      @db.SmallInt
  description           String?  @db.Text
  amenities             String[] @db.Text
  images                String[] @db.Text
  isActive              Boolean  @default(true)
  isWholeVenue          Boolean  @default(false)
  allowWithWholeVenue   Boolean  @default(false)
  allowMultipleBookings Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  reservations    Reservation[]

  @@index([name])
  @@index([isActive])
  @@index([isWholeVenue])
}

model EventType {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  color       String?  @db.VarChar(20)
  isActive    Boolean  @default(true)

  // Per-event-type extra hours pricing (null = use global defaults)
  standardHours  Int?                          // null → global default (6h)
  extraHourRate  Decimal?  @db.Decimal(10, 2)  // null → global default (500 zł), 0 → exempt

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reservations  Reservation[]
  menuTemplates MenuTemplate[]

  @@index([name])
  @@index([isActive])
}

// ═════════════════════════════════════════════════════════════════
// 👥 CLIENT SYSTEM — Individual & Company clients (#150 Klienci 2.0)
// ═════════════════════════════════════════════════════════════════

enum ClientType {
  INDIVIDUAL
  COMPANY
}

model Client {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  clientType  ClientType @default(INDIVIDUAL)

  firstName String   @db.VarChar(100)
  lastName  String   @db.VarChar(100)
  email     String?  @db.VarChar(255)
  phone     String   @db.VarChar(20)
  notes     String?  @db.Text

  companyName       String?  @db.VarChar(255)
  nip               String?  @db.VarChar(20)
  regon             String?  @db.VarChar(20)
  companyEmail      String?  @db.VarChar(255)
  companyPhone      String?  @db.VarChar(20)
  companyAddress    String?  @db.Text
  companyCity       String?  @db.VarChar(100)
  companyPostalCode String?  @db.VarChar(10)
  industry          String?  @db.VarChar(100)
  website           String?  @db.VarChar(255)

  isDeleted Boolean  @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reservations   Reservation[]
  contacts       ClientContact[]
  cateringOrders CateringOrder[]

  @@index([email])
  @@index([phone])
  @@index([firstName, lastName])
  @@index([isDeleted])
  @@index([clientType])
  @@index([nip])
  @@index([companyName])
}

model ClientContact {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId  String   @db.Uuid

  firstName String   @db.VarChar(100)
  lastName  String   @db.VarChar(100)
  email     String?  @db.VarChar(255)
  phone     String?  @db.VarChar(20)
  role      String?  @db.VarChar(100)
  isPrimary Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([isPrimary])
}

enum ReservationStatus {
  RESERVED
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  ARCHIVED
}

model Reservation {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  clientId        String   @db.Uuid
  createdById     String   @db.Uuid
  
  reservationQueuePosition Int?     @db.SmallInt
  reservationQueueDate     DateTime?
  queueOrderManual         Boolean  @default(false)
  
  hallId          String?  @db.Uuid
  eventTypeId     String?  @db.Uuid

  date            String?  @db.VarChar(10)
  startTime       String?  @db.VarChar(5)
  endTime         String?  @db.VarChar(5)
  
  startDateTime   DateTime?
  endDateTime     DateTime?
  
  adults          Int      @default(0) @db.SmallInt
  children        Int      @default(0) @db.SmallInt
  toddlers        Int      @default(0) @db.SmallInt
  guests          Int      @db.SmallInt
  
  pricePerAdult   Decimal  @default(0) @db.Decimal(10, 2)
  pricePerChild   Decimal  @default(0) @db.Decimal(10, 2)
  pricePerToddler Decimal  @default(0) @db.Decimal(10, 2)
  totalPrice      Decimal  @db.Decimal(10, 2)

  discountType        String?   @db.VarChar(20)
  discountValue       Decimal?  @db.Decimal(10, 2)
  discountAmount      Decimal?  @db.Decimal(10, 2)
  discountReason      String?   @db.Text
  priceBeforeDiscount Decimal?  @db.Decimal(10, 2)

  venueSurcharge      Decimal?  @db.Decimal(10, 2)
  venueSurchargeLabel String?   @db.VarChar(255)

  extraHoursCost      Decimal  @default(0) @db.Decimal(10, 2)
  
  status          ReservationStatus @default(RESERVED)
  confirmationDeadline DateTime?
  
  notes           String?  @db.Text
  internalNotes   String?  @db.Text

  customEventType String?  @db.VarChar(100)
  birthdayAge     Int?     @db.SmallInt
  anniversaryYear     Int?     @db.SmallInt
  anniversaryOccasion String?  @db.VarChar(100)

  attachments     String[] @db.Text
  archivedAt      DateTime?

  extrasTotalPrice Decimal  @default(0) @db.Decimal(10, 2)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  hall            Hall?     @relation(fields: [hallId], references: [id], onDelete: Restrict)
  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  eventType       EventType? @relation(fields: [eventTypeId], references: [id])
  createdBy       User      @relation("CreatedBy", fields: [createdById], references: [id])

  history         ReservationHistory[]
  deposits        Deposit[]
  menuSnapshot    ReservationMenuSnapshot?
  extras          ReservationExtra[]
  categoryExtras  ReservationCategoryExtra[]

  @@index([date])
  @@index([startDateTime])
  @@index([reservationQueueDate])
  @@index([reservationQueuePosition])
  @@index([hallId])
  @@index([clientId])
  @@index([status])
  @@index([createdById])
  @@index([confirmationDeadline])
  @@index([queueOrderManual])
}

model ReservationHistory {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservationId   String   @db.Uuid
  changedByUserId String   @db.Uuid

  changeType      String   @db.VarChar(20)
  fieldName       String?  @db.VarChar(100)
  oldValue        String?  @db.Text
  newValue        String?  @db.Text
  reason          String?  @db.Text

  createdAt       DateTime @default(now())

  reservation     Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  changedByUser   User @relation("ChangedBy", fields: [changedByUserId], references: [id])

  @@index([reservationId])
  @@index([changedByUserId])
  @@index([createdAt])
}

// ═════════════════════════════════════════════════════════════════
// 💰 DEPOSIT SYSTEM
// ═════════════════════════════════════════════════════════════════

model Deposit {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservationId       String   @db.Uuid

  amount              Decimal  @db.Decimal(10, 2)
  remainingAmount     Decimal  @db.Decimal(10, 2)
  paidAmount          Decimal  @default(0) @db.Decimal(10, 2)
  dueDate             String   @db.VarChar(10)
  status              String   @default("PENDING") @db.VarChar(20)
  paid                Boolean  @default(false)
  paidAt              DateTime?
  paymentMethod       String?  @db.VarChar(50)

  title               String?  @db.VarChar(255)
  description         String?  @db.Text
  internalNotes       String?  @db.Text
  receiptNumber       String?  @unique @db.VarChar(50)
  confirmationPdfUrl  String?  @db.Text
  reminderSentAt      DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  reservation         Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  payments            DepositPayment[]

  @@index([reservationId])
  @@index([dueDate])
  @@index([status])
  @@index([paid])
  @@index([receiptNumber])
  @@index([reminderSentAt])
}

model DepositPayment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  depositId     String   @db.Uuid

  amount        Decimal  @db.Decimal(10, 2)
  paymentMethod String?  @db.VarChar(50)
  paidAt        DateTime @default(now())
  notes         String?  @db.Text

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  deposit       Deposit  @relation(fields: [depositId], references: [id], onDelete: Cascade)

  @@index([depositId])
}

// ═════════════════════════════════════════════════════════════════

model ActivityLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String?  @db.Uuid

  action          String   @db.VarChar(100)
  entityType      String?  @db.VarChar(50)
  entityId        String?  @db.VarChar(100)
  details         Json?

  ipAddress       String?  @db.Inet
  userAgent       String?  @db.Text

  createdAt       DateTime @default(now())

  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

// ═════════════════════════════════════════════════════════════════
// 🍽️ MENU SYSTEM
// ═════════════════════════════════════════════════════════════════

model MenuTemplate {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventTypeId   String   @db.Uuid
  
  name          String   @db.VarChar(255)
  description   String?  @db.Text
  variant       String?  @db.VarChar(100)
  
  validFrom     DateTime?
  validTo       DateTime?
  isActive      Boolean  @default(true)
  
  displayOrder  Int      @default(0) @db.SmallInt
  imageUrl      String?  @db.Text
  thumbnailUrl  String?  @db.Text
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  eventType     EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  packages      MenuPackage[]
  priceHistory  MenuPriceHistory[]
  
  @@index([eventTypeId])
  @@index([isActive])
  @@index([validFrom, validTo])
  @@index([variant])
}

model MenuPackage {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  menuTemplateId  String   @db.Uuid
  
  name            String   @db.VarChar(255)
  description     String?  @db.Text
  shortDescription String? @db.VarChar(500)
  
  pricePerAdult   Decimal  @db.Decimal(10, 2)
  pricePerChild   Decimal  @default(0) @db.Decimal(10, 2)
  pricePerToddler Decimal  @default(0) @db.Decimal(10, 2)
  
  color           String?  @db.VarChar(20)
  icon            String?  @db.VarChar(50)
  badgeText       String?  @db.VarChar(50)
  displayOrder    Int      @default(0) @db.SmallInt
  isPopular       Boolean  @default(false)
  isRecommended   Boolean  @default(false)
  
  includedItems   String[] @db.Text
  
  minGuests       Int?     @db.SmallInt
  maxGuests       Int?     @db.SmallInt
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  menuTemplate    MenuTemplate @relation(fields: [menuTemplateId], references: [id], onDelete: Cascade)
  categorySettings PackageCategorySettings[]
  courses         MenuCourse[]
  priceHistory    MenuPriceHistory[]
  
  @@index([menuTemplateId])
  @@index([displayOrder])
  @@index([isPopular])
}

model MenuCourse {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  packageId     String   @db.Uuid

  name          String   @db.VarChar(255)
  description   String?  @db.Text

  minSelect     Int      @default(1) @db.SmallInt
  maxSelect     Int      @default(1) @db.SmallInt
  isRequired    Boolean  @default(true)
  displayOrder  Int      @default(0) @db.SmallInt
  icon          String?  @db.VarChar(50)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  package       MenuPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  options       MenuCourseOption[]

  @@index([packageId])
  @@index([displayOrder])
}

model MenuCourseOption {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId       String   @db.Uuid
  dishId        String   @db.Uuid

  customPrice   Decimal? @db.Decimal(10, 2)
  isDefault     Boolean  @default(false)
  isRecommended Boolean  @default(false)
  displayOrder  Int      @default(0) @db.SmallInt

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  course        MenuCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  dish          Dish @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@unique([courseId, dishId])
  @@index([courseId])
  @@index([dishId])
}

// ═════════════════════════════════════════════════════════════════
// 🍽️ DISH LIBRARY & DYNAMIC CATEGORY SYSTEM
// ═════════════════════════════════════════════════════════════════

model DishCategory {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  slug          String   @unique @db.VarChar(50)
  name          String   @db.VarChar(100)
  icon          String?  @db.VarChar(20)
  color         String?  @db.VarChar(50)
  
  displayOrder  Int      @default(0) @db.SmallInt
  isActive      Boolean  @default(true)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  dishes           Dish[]
  categorySettings PackageCategorySettings[]
  cateringSections CateringPackageSection[]
  
  @@index([slug])
  @@index([isActive])
  @@index([displayOrder])
}

model Dish {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId    String        @db.Uuid
  
  name          String        @db.VarChar(255)
  description   String?       @db.Text
  
  allergens     String[]      @db.Text
  
  isActive      Boolean       @default(true)
  displayOrder  Int           @default(0) @db.SmallInt
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  category        DishCategory     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  courseOptions   MenuCourseOption[]
  cateringOptions CateringSectionOption[]
  orderItems      CateringOrderItem[]
  
  @@index([categoryId])
  @@index([isActive])
  @@index([name])
}

model PackageCategorySettings {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  packageId     String        @db.Uuid
  categoryId    String        @db.Uuid
  
  minSelect     Decimal       @default(1) @db.Decimal(4, 1)
  maxSelect     Decimal       @default(1) @db.Decimal(4, 1)
  
  isRequired    Boolean       @default(true)
  isEnabled     Boolean       @default(true)
  portionTarget String        @default("ALL") @db.VarChar(20)
  
  displayOrder  Int           @default(0) @db.SmallInt
  customLabel   String?       @db.VarChar(255)

  extraItemPrice Decimal?     @db.Decimal(10, 2)
  maxExtra       Decimal?     @db.Decimal(4, 1)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  package       MenuPackage   @relation(fields: [packageId], references: [id], onDelete: Cascade)
  category      DishCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  reservationExtras ReservationCategoryExtra[]

  @@unique([packageId, categoryId])
  @@index([packageId])
  @@index([categoryId])
}

model ReservationCategoryExtra {
  id                String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservationId     String                  @db.Uuid
  packageCategoryId String                  @db.Uuid

  quantity          Decimal                 @db.Decimal(4, 1)
  pricePerItem      Decimal                 @db.Decimal(10, 2)
  totalPrice        Decimal                 @db.Decimal(10, 2)
  guestCount        Int                     @default(1)
  portionTarget     String                  @default("ALL") @db.VarChar(20)

  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  reservation       Reservation             @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  packageCategory   PackageCategorySettings  @relation(fields: [packageCategoryId], references: [id])

  @@unique([reservationId, packageCategoryId])
  @@index([reservationId])
  @@index([packageCategoryId])
}

model ReservationMenuSnapshot {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservationId   String   @unique @db.Uuid
  
  menuData        Json
  
  menuTemplateId  String?  @db.Uuid
  packageId       String?  @db.Uuid
  
  packagePrice    Decimal  @db.Decimal(10, 2)
  optionsPrice    Decimal  @default(0) @db.Decimal(10, 2)
  totalMenuPrice  Decimal  @db.Decimal(10, 2)
  
  adultsCount     Int      @db.SmallInt
  childrenCount   Int      @db.SmallInt
  toddlersCount   Int      @db.SmallInt
  
  selectedAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  reservation     Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  
  @@index([reservationId])
  @@index([menuTemplateId])
  @@index([packageId])
  @@index([selectedAt])
}

model MenuPriceHistory {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  entityType      String   @db.VarChar(50)
  entityId        String   @db.Uuid
  
  menuTemplateId  String?  @db.Uuid
  packageId       String?  @db.Uuid
  
  fieldName       String   @db.VarChar(50)
  oldValue        Decimal  @db.Decimal(10, 2)
  newValue        Decimal  @db.Decimal(10, 2)
  changeReason    String?  @db.Text
  
  effectiveFrom   DateTime @default(now())
  
  createdAt       DateTime @default(now())
  
  menuTemplate    MenuTemplate? @relation(fields: [menuTemplateId], references: [id], onDelete: Cascade)
  package         MenuPackage? @relation(fields: [packageId], references: [id], onDelete: Cascade)
  
  @@index([entityType, entityId])
  @@index([menuTemplateId])
  @@index([packageId])
  @@index([effectiveFrom])
}

// ═════════════════════════════════════════════════════════════════
// 📎 ATTACHMENT SYSTEM (#146 — SHA-256 dedup)
// ═════════════════════════════════════════════════════════════════

model Attachment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  entityType    String   @db.VarChar(50)
  entityId      String   @db.Uuid

  category      String   @db.VarChar(50)
  label         String?  @db.VarChar(255)

  originalName  String   @db.VarChar(255)
  storedName    String   @db.VarChar(255)
  mimeType      String   @db.VarChar(100)
  sizeBytes     Int
  storagePath   String   @db.Text
  fileHash      String?  @db.VarChar(64)

  uploadedById  String   @db.Uuid
  description   String?  @db.Text
  isArchived    Boolean  @default(false)
  version       Int      @default(1) @db.SmallInt

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  uploadedBy    User     @relation("UploadedBy", fields: [uploadedById], references: [id])

  @@index([entityType, entityId])
  @@index([category])
  @@index([uploadedById])
  @@index([createdAt])
  @@index([fileHash])
}

// ═════════════════════════════════════════════════════════════════
// 🎁 SERVICE EXTRAS
// ═════════════════════════════════════════════════════════════════

model ServiceCategory {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  name          String   @db.VarChar(100)
  slug          String   @unique @db.VarChar(50)
  description   String?  @db.Text
  icon          String?  @db.VarChar(20)
  color         String?  @db.VarChar(50)

  displayOrder  Int      @default(0) @db.SmallInt
  isActive      Boolean  @default(true)
  isExclusive   Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items         ServiceItem[]

  @@index([slug])
  @@index([isActive])
  @@index([displayOrder])
}

model ServiceItem {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId    String   @db.Uuid

  name          String   @db.VarChar(255)
  description   String?  @db.Text

  priceType     String   @db.VarChar(20)
  basePrice     Decimal  @default(0) @db.Decimal(10, 2)

  icon          String?  @db.VarChar(50)
  displayOrder  Int      @default(0) @db.SmallInt

  requiresNote  Boolean  @default(false)
  noteLabel     String?  @db.VarChar(255)

  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category      ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  reservationExtras ReservationExtra[]
  cateringExtras    CateringOrderExtra[]

  @@index([categoryId])
  @@index([isActive])
  @@index([displayOrder])
  @@index([priceType])
}

model ReservationExtra {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservationId   String   @db.Uuid
  serviceItemId   String   @db.Uuid

  quantity        Int      @default(1) @db.SmallInt
  unitPrice       Decimal  @db.Decimal(10, 2)
  priceType       String   @db.VarChar(20)
  totalPrice      Decimal  @db.Decimal(10, 2)

  note            String?  @db.Text
  status          String   @default("PENDING") @db.VarChar(20)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reservation     Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  serviceItem     ServiceItem @relation(fields: [serviceItemId], references: [id], onDelete: Restrict)

  @@unique([reservationId, serviceItemId])
  @@index([reservationId])
  @@index([serviceItemId])
  @@index([status])
}

// ═════════════════════════════════════════════════════════════════
// 📝 DOCUMENT TEMPLATE SYSTEM (#151)
// ═════════════════════════════════════════════════════════════════

model DocumentTemplate {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug          String   @unique @db.VarChar(100)
  name          String   @db.VarChar(255)
  description   String?  @db.Text
  category      String   @db.VarChar(50)
  format        String   @default("MARKDOWN") @db.VarChar(20)
  content       String   @db.Text
  availableVars String[] @db.Text
  version       Int      @default(1) @db.SmallInt
  isActive      Boolean  @default(true)
  isRequired    Boolean  @default(false)
  displayOrder  Int      @default(0) @db.SmallInt
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  history       DocumentTemplateHistory[]

  @@index([slug])
  @@index([category])
  @@index([isActive])
  @@index([displayOrder])
}

model DocumentTemplateHistory {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId    String   @db.Uuid
  content       String   @db.Text
  version       Int      @db.SmallInt
  changedById   String   @db.Uuid
  changeReason  String?  @db.Text
  createdAt     DateTime @default(now())

  template      DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  changedBy     User @relation(fields: [changedById], references: [id])

  @@index([templateId])
  @@index([changedById])
  @@index([version])
}

// ═════════════════════════════════════════════════════════════════
// 🍱 CATERING MODULE — Faza 1: Szablony i Pakiety (#150)
// ═════════════════════════════════════════════════════════════════

enum CateringPriceType {
  PER_PERSON
  FLAT
  TIERED
}

model CateringTemplate {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String   @db.VarChar(255)
  description   String?  @db.Text
  slug          String   @unique @db.VarChar(100)
  imageUrl      String?  @db.Text
  isActive      Boolean  @default(true)
  displayOrder  Int      @default(0) @db.SmallInt
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  packages      CateringPackage[]
  orders        CateringOrder[]

  @@index([slug])
  @@index([isActive])
  @@index([displayOrder])
}

model CateringPackage {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId        String            @db.Uuid

  name              String            @db.VarChar(255)
  description       String?           @db.Text
  shortDescription  String?           @db.VarChar(500)

  priceType         CateringPriceType @default(PER_PERSON)
  basePrice         Decimal           @default(0) @db.Decimal(10, 2)
  // tieredPricing JSON: [{minGuests,maxGuests,pricePerPerson}]
  tieredPricing     Json?

  badgeText         String?           @db.VarChar(50)
  isPopular         Boolean           @default(false)
  displayOrder      Int               @default(0) @db.SmallInt
  isActive          Boolean           @default(true)

  minGuests         Int?              @db.SmallInt
  maxGuests         Int?              @db.SmallInt

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  template          CateringTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sections          CateringPackageSection[]
  orders            CateringOrder[]

  @@index([templateId])
  @@index([displayOrder])
  @@index([isActive])
}

model CateringPackageSection {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  packageId     String          @db.Uuid
  categoryId    String          @db.Uuid

  name          String?         @db.VarChar(255)
  description   String?         @db.Text
  // Decimal(4,2) — obsługuje wartości ćwiartkowe: 0.25, 0.5, 0.75, 1.0, 1.25 ...
  minSelect     Decimal         @default(1) @db.Decimal(4, 2)
  // nullable: null = bez limitu górnego wyboru
  maxSelect     Decimal?        @db.Decimal(4, 2)
  isRequired    Boolean         @default(true)
  displayOrder  Int             @default(0) @db.SmallInt

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  package       CateringPackage   @relation(fields: [packageId], references: [id], onDelete: Cascade)
  category      DishCategory      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  options       CateringSectionOption[]

  @@unique([packageId, categoryId])
  @@index([packageId])
  @@index([categoryId])
  @@index([displayOrder])
}

model CateringSectionOption {
  id            String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sectionId     String                 @db.Uuid
  dishId        String                 @db.Uuid

  customPrice   Decimal?               @db.Decimal(10, 2)
  isDefault     Boolean                @default(false)
  displayOrder  Int                    @default(0) @db.SmallInt

  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  section       CateringPackageSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  dish          Dish                   @relation(fields: [dishId], references: [id], onDelete: Restrict)

  @@unique([sectionId, dishId])
  @@index([sectionId])
  @@index([dishId])
}

// ═════════════════════════════════════════════════════════════════
// 🍱 CATERING MODULE — Faza 2: Zamówienia (#150)
// ═════════════════════════════════════════════════════════════════

enum CateringOrderStatus {
  DRAFT
  INQUIRY
  QUOTED
  CONFIRMED
  IN_PREPARATION
  READY
  DELIVERED
  COMPLETED
  CANCELLED
}

enum CateringDeliveryType {
  PICKUP
  DELIVERY
  ON_SITE
}

enum CateringDiscountType {
  PERCENTAGE
  AMOUNT
}

model CateringOrder {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Auto-numbering: CAT-YYYY-XXXXX
  orderNumber     String               @unique @db.VarChar(20)

  clientId        String               @db.Uuid
  createdById     String               @db.Uuid

  // Powiązanie z szablonem i pakietem cateringowym
  templateId      String?              @db.Uuid
  packageId       String?              @db.Uuid

  status          CateringOrderStatus  @default(DRAFT)
  deliveryType    CateringDeliveryType @default(ON_SITE)

  // Informacje o wydarzeniu
  eventName       String?              @db.VarChar(255)
  eventDate       String?              @db.VarChar(10)   // YYYY-MM-DD
  eventTime       String?              @db.VarChar(5)    // HH:MM
  eventLocation   String?              @db.VarChar(255)

  // Goście
  guestsCount     Int                  @default(0) @db.SmallInt

  // Logistyka dostawy
  deliveryAddress String?              @db.Text
  deliveryNotes   String?              @db.Text
  deliveryDate    String?              @db.VarChar(10)   // YYYY-MM-DD
  deliveryTime    String?              @db.VarChar(5)    // HH:MM

  // Cennik
  subtotal        Decimal              @default(0) @db.Decimal(10, 2)
  extrasTotalPrice Decimal             @default(0) @db.Decimal(10, 2)
  discountType    CateringDiscountType?
  discountValue   Decimal?             @db.Decimal(10, 2)
  discountAmount  Decimal?             @db.Decimal(10, 2)
  discountReason  String?              @db.Text
  totalPrice      Decimal              @default(0) @db.Decimal(10, 2)

  // Kontakt
  contactName     String?              @db.VarChar(200)
  contactPhone    String?              @db.VarChar(20)
  contactEmail    String?              @db.VarChar(255)

  // Uwagi
  notes           String?              @db.Text
  internalNotes   String?              @db.Text
  specialRequirements String?          @db.Text

  // Termin ważności oferty (QUOTED → CONFIRMED)
  quoteExpiresAt  DateTime?

  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  client          Client               @relation(fields: [clientId], references: [id], onDelete: Restrict)
  createdBy       User                 @relation("CateringOrderCreatedBy", fields: [createdById], references: [id])
  template        CateringTemplate?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  package         CateringPackage?     @relation(fields: [packageId], references: [id], onDelete: SetNull)

  items           CateringOrderItem[]
  extras          CateringOrderExtra[]
  history         CateringOrderHistory[]
  deposits        CateringDeposit[]

  @@index([orderNumber])
  @@index([clientId])
  @@index([createdById])
  @@index([status])
  @@index([deliveryType])
  @@index([eventDate])
  @@index([createdAt])
  @@index([templateId])
  @@index([packageId])
}

model CateringOrderItem {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId     String        @db.Uuid
  dishId      String        @db.Uuid

  quantity    Int           @default(1) @db.SmallInt
  unitPrice   Decimal       @db.Decimal(10, 2)
  totalPrice  Decimal       @db.Decimal(10, 2)
  note        String?       @db.Text

  // Snapshot nazwy dania w momencie zamówienia
  dishNameSnapshot  String  @db.VarChar(255)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order       CateringOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  dish        Dish          @relation(fields: [dishId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([dishId])
}

model CateringOrderExtra {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId       String        @db.Uuid
  serviceItemId String?       @db.Uuid

  name          String        @db.VarChar(255)
  description   String?       @db.Text
  quantity      Int           @default(1) @db.SmallInt
  unitPrice     Decimal       @db.Decimal(10, 2)
  totalPrice    Decimal       @db.Decimal(10, 2)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order         CateringOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  serviceItem   ServiceItem?  @relation(fields: [serviceItemId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([serviceItemId])
}

model CateringOrderHistory {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId     String        @db.Uuid
  changedById String        @db.Uuid

  changeType  String        @db.VarChar(30)
  fieldName   String?       @db.VarChar(100)
  oldValue    String?       @db.Text
  newValue    String?       @db.Text
  reason      String?       @db.Text

  createdAt   DateTime      @default(now())

  order       CateringOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy   User          @relation("CateringOrderChangedBy", fields: [changedById], references: [id])

  @@index([orderId])
  @@index([changedById])
  @@index([createdAt])
}

model CateringDeposit {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId         String        @db.Uuid

  amount          Decimal       @db.Decimal(10, 2)
  paidAmount      Decimal       @default(0) @db.Decimal(10, 2)
  remainingAmount Decimal       @db.Decimal(10, 2)
  dueDate         String        @db.VarChar(10)   // YYYY-MM-DD
  status          String        @default("PENDING") @db.VarChar(20)
  paid            Boolean       @default(false)
  paidAt          DateTime?
  paymentMethod   String?       @db.VarChar(50)

  title           String?       @db.VarChar(255)
  description     String?       @db.Text
  internalNotes   String?       @db.Text
  receiptNumber   String?       @unique @db.VarChar(50)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  order           CateringOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([dueDate])
  @@index([status])
  @@index([paid])
}

// ═════════════════════════════════════════════════════════════════
// 🔔 NOTIFICATIONS (#128 — powiadomienia real-time)
// ═════════════════════════════════════════════════════════════════

model Notification {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @db.Uuid
  type        String   @db.VarChar(50)   // RESERVATION_CREATED, STATUS_CHANGED, DEPOSIT_OVERDUE, DEPOSIT_REMINDER, QUEUE_PROMOTED, RESERVATION_UPDATED
  title       String   @db.VarChar(255)
  message     String   @db.Text
  read        Boolean  @default(false)
  entityType  String?  @db.VarChar(50)   // RESERVATION, CLIENT, DEPOSIT, QUEUE
  entityId    String?  @db.Uuid
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
}
